# ============================================================
#  Production Environment Configuration
#  Copy to .env and fill in your values
# ============================================================

# Domain Configuration
DOMAIN=your-domain.com
EMAIL=admin@your-domain.com

# Database (PostgreSQL for production)
DB_USER=jobapplier
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD_32CHARS
DB_NAME=jobapplier

# Database URL (auto-constructed)
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}?sslmode=disable

# JWT Configuration
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
JWT_EXPIRY=24h

# Python Service
PYTHON_SERVICE_URL=http://python-service:8001

# LLM Configuration
LLM_API_KEY=your-openai-or-anthropic-api-key
LLM_MODEL=gpt-4o-mini

# Server
SERVER_PORT=8080
GIN_MODE=release

# CORS
CORS_ALLOWED_ORIGINS=https://${DOMAIN},https://www.${DOMAIN}

# Optional: Redis (if added later)
# REDIS_URL=redis://redis:6379

# Optional: Email notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Logging
LOG_LEVEL=info
