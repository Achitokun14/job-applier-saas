# Database
DATABASE_URL=postgres://jobapplier:changeme@localhost:5432/jobapplier?sslmode=disable

# JWT (MUST change in production, minimum 32 characters)
JWT_SECRET=your-secret-key-change-in-production-min-32-chars
JWT_EXPIRY=24h
APP_ENV=development

# Python Service
PYTHON_SERVICE_URL=http://localhost:8001

# LLM Configuration
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_PROVIDER=openai

# Redis
REDIS_URL=localhost:6379

# Encryption (32+ character key for AES-256-GCM)
ENCRYPTION_KEY=your-encryption-key-change-in-prod

# Stripe Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=

# Monitoring
SENTRY_DSN=
GRAFANA_PASSWORD=admin

# CORS (comma-separated, or * for development)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database Password
DB_PASSWORD=changeme
